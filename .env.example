# exSafe environment — copy to .env.local and fill what you have.
# The app runs with NONE of these set (graceful degradation), so you can demo
# immediately and add keys to unlock more signals.

# ---- Claude (recommended for Vibeathon demo) --------------------------------
# Powers the plain-language verdict narration and the announcement analyzer.
# Without it: deterministic explanations + keyword-based announcement heuristics.
# Set this on Vercel Production for podium-quality narration.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
# Narration language for API/web: "en" or "id"
NARRATION_LANG=en

# ---- Etherscan (optional, recommended) --------------------------------------
# Adds "verified source" + contract-age signals. Free key: https://etherscan.io/apis
# Etherscan v2 uses a single key across all supported chains.
ETHERSCAN_API_KEY=

# ---- GoPlus (optional) -------------------------------------------------------
# GoPlus works WITHOUT a key at lower rate limits. Keys just raise the limit.
GOPLUS_APP_KEY=
GOPLUS_APP_SECRET=

# ---- Defaults ----------------------------------------------------------------
# Base-first (Vibestarter / Wave 1). Use 1 for Ethereum mainnet default.
DEFAULT_CHAIN_ID=8453

# Public site URL used when building shareable verdict links (optional).
# Example: https://exsafe-mu.vercel.app
NEXT_PUBLIC_SITE_URL=

# Public GitHub repo link shown in the footer.
NEXT_PUBLIC_GITHUB_URL=https://github.com/aricandra3/exsafe

# ---- Discord bot -------------------------------------------------------------
# 1. Create an app: https://discord.com/developers/applications
# 2. Bot tab -> enable "MESSAGE CONTENT INTENT" (required for auto-scan).
# 3. Invite with scopes: bot, applications.commands
#    (perms: Send Messages, Embed Links, Read Message History).
# 4. Paste the generated invite URL below so the landing page can show "Add to Discord".
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
# Optional: register slash commands instantly to one test server.
DISCORD_GUILD_ID=
# Public bot invite (safe to expose). Landing CTA uses this when set.
NEXT_PUBLIC_DISCORD_INVITE=
# Where the bot reaches the web API (the shared "brain").
EXSAFE_API_URL=http://localhost:3000
