# exSafe environment — copy to .env.local and fill what you have.
# The app runs with NONE of these set (graceful degradation), so you can demo
# immediately and add keys to unlock more signals.

# ---- Claude (recommended) --------------------------------------------------
# Powers the plain-language verdict narration and the announcement analyzer.
# Without it: deterministic explanations + keyword-based announcement heuristics.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
# Narration language for API/web: "en" or "id"
NARRATION_LANG=en

# ---- Etherscan (optional) --------------------------------------------------
# Adds "verified source" + contract-age signals. Free key: https://etherscan.io/apis
# Etherscan v2 uses a single key across all supported chains.
ETHERSCAN_API_KEY=

# ---- GoPlus (optional) -----------------------------------------------------
# GoPlus works WITHOUT a key at lower rate limits. Keys just raise the limit.
GOPLUS_APP_KEY=
GOPLUS_APP_SECRET=

# ---- Defaults --------------------------------------------------------------
DEFAULT_CHAIN_ID=1

# ---- Discord bot -----------------------------------------------------------
# 1. Create an app: https://discord.com/developers/applications
# 2. Bot tab -> enable "MESSAGE CONTENT INTENT" (required for auto-scan).
# 3. Invite with scopes: bot, applications.commands (perms: Send Messages, Embed Links).
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
# Optional: register slash commands instantly to one test server.
DISCORD_GUILD_ID=
# Where the bot reaches the web API (the shared "brain").
EXSAFE_API_URL=http://localhost:3000
